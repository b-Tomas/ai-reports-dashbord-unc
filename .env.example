# --- Supabase (SPEC §6) ---
# Public — safe to expose to the client.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER ship to the client (used via $env/static|dynamic/private).
SUPABASE_SERVICE_ROLE_KEY=

# First admin seeded into dashboard_access on bootstrap.
SUPER_ADMIN_EMAIL=

# Google OAuth is configured in the Supabase Auth dashboard (no app env vars).
